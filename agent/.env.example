# =============================================================================
# Koi Voice Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# -- LiveKit --
LIVEKIT_URL=wss://your-livekit-server.example.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# -- Sarvam AI --
SARVAM_API_KEY=

# -- Supabase (Postgres) --
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -- Pinecone (Memory) --
PINECONE_API_KEY=
PINECONE_INDEX_NAME=koi-memories

# -- Langfuse Observability --
# Set to "true" to enable LLM tracing via Langfuse.
# Sign up at https://cloud.langfuse.com or self-host.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Set to "true" to include actual conversation text in traces.
# WARNING: Keep "false" in production to protect user privacy.
TRACE_CONTENT=false
